{
  "name": "epm",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manage-products": "cds watch --open manageproducts/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-manage-pos": "cds watch --open managepos/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "model": "db",
        "credentials": {
          "database": "epm.db"
        }
      },
      "auth": {
        "kind": "xsuaa",
        "[development]": {
          "kind": "mocked",
          "users": {
            "viewer@test.com": {
              "password": "pass",
              "roles": [
                "Viewer"
              ]
            },
            "manager@test.com": {
              "password": "pass",
              "roles": [
                "PurchaseManager"
              ]
            },
            "admin@test.com": {
              "password": "pass",
              "roles": [
                "Administrator"
              ]
            }
          }
        }
      },
      "[production]": {
        "auth": "xsuaa"
      }
    }
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/project1",
    "app/manage-products",
    "app/manage-pos"
  ]
}